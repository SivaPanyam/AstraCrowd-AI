# Core Build Exclusions
node_modules/
dist/
build/
.tsbuildinfo

# Python Compilation Exclusions
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/

# Environment Variables & Private Credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*

# Sensitive Credentials / Certificates
*.json
!package.json
!tsconfig.json
!tsconfig.*.json
!vite.config.ts
!manifest.webmanifest
# Block explicit service account json key files
*service-account*.json
*firebase-key*.json
*credentials*.json

# OS Exclusions
.DS_Store
Thumbs.db
Desktop.ini
